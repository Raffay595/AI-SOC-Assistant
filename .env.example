# ============================================
# AI SOC Assistant — Environment Configuration
# ============================================

# OpenRouter API Key (get from https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# AI Model (any OpenRouter model slug)
# Options: anthropic/claude-sonnet-4, openai/gpt-4o, google/gemini-2.5-flash,
#          deepseek/deepseek-chat, qwen/qwen-2.5-72b-instruct
AI_MODEL=anthropic/claude-sonnet-4

# AI Parameters
AI_TEMPERATURE=0.3
AI_MAX_TOKENS=4096
AI_TIMEOUT=60

# Database
DATABASE_URL=sqlite:///./database/soc.db

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Frontend
FRONTEND_PORT=8501
BACKEND_URL=http://localhost:8000
